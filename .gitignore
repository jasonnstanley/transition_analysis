# ---------------------------------------------------------------------------
# Private research data
# ---------------------------------------------------------------------------

data/raw/
data/secure/

# ---------------------------------------------------------------------------
# Python virtual environment
# ---------------------------------------------------------------------------

.venv/

# ---------------------------------------------------------------------------
# Python cache
# ---------------------------------------------------------------------------

__pycache__/
*.py[cod]
*$py.class

# ---------------------------------------------------------------------------
# Log files only
# ---------------------------------------------------------------------------

# Build logs
logs/*.log



# ---------------------------------------------------------------------------
# Operating system files
# ---------------------------------------------------------------------------

Thumbs.db
Desktop.ini

# macOS
.DS_Store

# ---------------------------------------------------------------------------
# IDE settings
# ---------------------------------------------------------------------------

.vscode/
.idea/

# ---------------------------------------------------------------------------
# Personal working notes
# ---------------------------------------------------------------------------

for_GPT*.txt
progress_so_far.txt
*-history.txt

# ---------------------------------------------------------------------------
# Temporary files
# ---------------------------------------------------------------------------

*.tmp
*.bak
*.swp

